# ── Backend API ──────────────────────────────────────────────────────────────
# Server-side (Nuxt SSR → backend, not exposed to browser)
NUXT_API_BASE=http://localhost:8080

# Client-side (browser → backend, needs CORS)
NUXT_PUBLIC_API_BASE=http://localhost:8080

# ── Development override ──────────────────────────────────────────────────────
# In production, backend resolves the site by Hostname automatically.
# During local dev, set your webSiteId here so the right site loads.
NUXT_WEB_SITE_ID=123e4567-e89b-12d3-a456-426614174000
NUXT_PUBLIC_WEB_SITE_ID=123e4567-e89b-12d3-a456-426614174000

# ── Defaults ──────────────────────────────────────────────────────────────────
NUXT_PUBLIC_DEFAULT_LOCALE=zh-tw
NUXT_PUBLIC_DEFAULT_SLUG=home
