# ── Backend API ───────────────────────────────────────────────────────────────
# Server-side (SSR → backend)
NUXT_API_BASE=https://xxx.angke.com.tw

# Client-side (browser → backend)
NUXT_PUBLIC_API_BASE=https://xxx.angke.com.tw

# ── Site ID ───────────────────────────────────────────────────────────────────
# 不需要填，後端用子網域自動判斷
# 未來若子網域 xxx.domain.com → 對應 https://xxx.angke.com.tw
NUXT_WEB_SITE_ID=
NUXT_PUBLIC_WEB_SITE_ID=

# ── Dev host override ─────────────────────────────────────────────────────────
# 本機開發時 host 是 localhost，後端找不到網站
# 這裡填主網域，SSR 會把這個 host 轉送給後端讓它正確解析
NUXT_DEV_HOST=xxx.angke.com.tw

# ── Defaults ──────────────────────────────────────────────────────────────────
NUXT_PUBLIC_DEFAULT_LOCALE=zh-tw
NUXT_PUBLIC_DEFAULT_SLUG=home

# ── Login URL ─────────────────────────────────────────────────────────────────
NUXT_PUBLIC_LOGIN_URL=http://xxx.angke.com.tw/backend

# ── 網站前綴 ─────────────────────────────────────────────────────────────────
NUXT_PUBLIC_BASE_URL=